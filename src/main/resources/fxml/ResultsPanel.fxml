<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plainquery.controller.ResultsController"
      spacing="0" styleClass="results-panel">

    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="results-toolbar">
        <padding><Insets top="6" bottom="6" left="8" right="8"/></padding>
        <Label text="Filter:" styleClass="filter-label"/>
        <TextField fx:id="filterField"
                   promptText="Filter rows..."
                   prefWidth="200"
                   styleClass="filter-field"
                   HBox.hgrow="NEVER"/>
        <Button fx:id="exportButton" text="Export CSV"
                onAction="#onExport" styleClass="secondary-button"/>
        <Label fx:id="rowCountLabel" text="" styleClass="row-count-label"/>
    </HBox>

    <TableView fx:id="resultsTable"
               VBox.vgrow="ALWAYS"
               styleClass="results-table"
               placeholder="&lt;Label text='No results to display'/&gt;">
    </TableView>

</VBox>
